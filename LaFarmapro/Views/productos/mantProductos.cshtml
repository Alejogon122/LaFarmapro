
@model IEnumerable<LaFarmapro.Models.viewModels.CListaProductos>

@{
    ViewBag.Title = "Mantenimiento de Productos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><span class="glyphicon glyphicon-list"></span> Productos</h2>
        @Html.ActionLink("+ Agregar Producto", "agregarProducto", "Productos", null, new { @class = "btn btn-success" })
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            @TempData["SuccessMessage"]
        </div>
    }

    <table class="table table-striped table-bordered table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.idProducto</td>
                    <td>@item.nombreProducto</td>
                    <td>@item.descripcionProducto</td>
                    <td>₡@item.precioProducto.ToString("N2")</td>
                    <td>
                        @if (item.estadoProducto == "Activo")
                        {
                            <span class="label label-success">@item.estadoProducto</span>
                        }
                        else
                        {
                            <span class="label label-danger">@item.estadoProducto</span>
                        }
                    </td>
                    <td>
                        @Html.ActionLink("Ver", "consultarProducto", new { id = item.idProducto }, new { @class = "btn btn-info btn-xs" })
                        @Html.ActionLink("Editar", "actualizarProducto", new { id = item.idProducto }, new { @class = "btn btn-warning btn-xs" })
                        @Html.ActionLink("Eliminar", "eliminarProducto", new { id = item.idProducto }, new { @class = "btn btn-danger btn-xs", onclick = "return confirm('¿Está seguro que desea eliminar este producto?');" })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay productos registrados.</div>
    }
</div>


