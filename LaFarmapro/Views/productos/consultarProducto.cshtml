
@model LaFarmapro.Models.viewModels.CListaProductos

@{
    ViewBag.Title = "Detalle del Producto";
}

<div class="container mt-4">
    <h2>Detalle del Producto</h2>
    <hr />

    <div class="panel panel-default">
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>Código</dt>
                <dd>@Model.codigoProducto</dd>

                <dt>Nombre</dt>
                <dd>@Model.nombreProducto</dd>

                <dt>Descripción</dt>
                <dd>@Model.descripcionProducto</dd>

                <dt>Precio</dt>
                <dd>₡@Model.precioProducto.ToString("N2")</dd>

                <dt>Estado</dt>
                <dd>
                    @if (Model.estadoProducto == "Activo")
                    {
                        <span class="label label-success">@Model.estadoProducto</span>
                    }
                    else
                    {
                        <span class="label label-danger">@Model.estadoProducto</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("Editar", "actualizarProducto", new { id = Model.idProducto }, new { @class = "btn btn-warning" })
        @Html.ActionLink("Volver a la lista", "mantProductos", null, new { @class = "btn btn-default" })
    </div>
</div>



