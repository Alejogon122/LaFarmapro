

@model LaFarmapro.Models.viewModels.CAgregarProducto

@{
    ViewBag.Title = "Agregar Producto";
}

<div class="container mt-4">
    <h2>Agregar Producto</h2>
    <hr />

    @using (Html.BeginForm("agregarProducto", "Productos", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(m => m.nombreProducto, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.nombreProducto, new { @class = "form-control", placeholder = "Nombre del producto" })
                    @Html.ValidationMessageFor(m => m.nombreProducto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.descripcionProducto, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextAreaFor(m => m.descripcionProducto, new { @class = "form-control", rows = "3", placeholder = "Descripción del producto" })
                    @Html.ValidationMessageFor(m => m.descripcionProducto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.precioProducto, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.precioProducto, new { @class = "form-control", placeholder = "0.00", type = "number", step = "0.01", min = "0" })
                    @Html.ValidationMessageFor(m => m.precioProducto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.estadoProducto, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.DropDownListFor(m => m.estadoProducto,
                        new SelectList(new[] {
                            new { Value = "AGOTADO", Text = "AGOTADO" },
                            new { Value = "EN_EXISTENCIA", Text = "EN EXISTENCIA" }
                        }, "Value", "Text"),
                        "-- Seleccione --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.estadoProducto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-3 col-md-6">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    @Html.ActionLink("Cancelar", "mantProductos", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    }
</div>
