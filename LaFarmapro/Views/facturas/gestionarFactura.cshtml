@model LaFarmapro.Models.viewModels.CFacturaCompleta
@using System.Globalization

@{
    bool esNueva = Model.idFactura == 0;
    ViewBag.Title = esNueva ? "Nueva Factura" : "Editar Factura #" + Model.idFactura;
}

<div class="container mt-4">

    <div class="page-header">
        <h2>
            <span class="glyphicon glyphicon-file"></span>
            @ViewBag.Title
        </h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @using (Html.BeginForm("guardarFacturaCompleta", "Facturas", FormMethod.Post, new { id = "formFactura" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.idFactura)

        <!-- ===== SECCIÓN 1: ENCABEZADO DE FACTURA ===== -->
        <div class="panel panel-primary">
            <br />
            <div class="panel-heading"><strong>Datos de la Factura</strong></div>
            <br />
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(m => m.fecha)
                            @Html.TextBoxFor(m => m.fecha, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.fecha, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(m => m.metodoPago)
                            @Html.DropDownListFor(m => m.metodoPago,
                                new SelectList(new[] {
                                    new { Value = "EFECTIVO", Text = "Efectivo" },
                                    new { Value = "TARJETA", Text = "Tarjeta" },

                                }, "Value", "Text"),
                                "-- Seleccione --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.metodoPago, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(m => m.idCliente)
                            @Html.DropDownListFor(m => m.idCliente, Model.Clientes,
                                "-- Seleccione cliente --", new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.idCliente, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== SECCIÓN 2: DETALLE DE PRODUCTOS ===== -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <br />  <br />
                <strong>Detalle de Productos</strong>
                <button type="button" class="btn btn-success btn-xs pull-right" id="btnAgregarFila">
                    <span class="glyphicon glyphicon-plus"></span> Agregar producto
                </button>
                <br /> <br />
            </div>
            <div class="panel-body">
                <table class="table table-bordered table-hover" id="tablaDetalles">
                    <thead class="thead-dark">
                        <tr>
                            <th style="width:35%">Producto</th>
                            <th style="width:15%">Cantidad</th>
                            <th style="width:20%">Precio Unidad (₡)</th>
                            <th style="width:20%">Subtotal (₡)</th>
                            <th style="width:10%"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyDetalles">

                        @* Filas de detalles existentes (al editar) *@
                        @if (Model.detalles != null && Model.detalles.Any())
                        {
                            foreach (var d in Model.detalles)
                            {
                                <tr>
                                    <td>
                                        <div>
                                            <select name="idProducto" class="form-control sel-producto">
                                                <option value="">-- Seleccione --</option>
                                                @foreach (var p in Model.Productos)
                                                {
                                                    if (p.Value == d.idProducto.ToString())
                                                    {
                                                        <option value="@p.Value" selected>@p.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@p.Value">@p.Text</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="number" name="cantidad" class="form-control inp-cantidad" value="0" min="0" />
                                    </td>
                                    <td>
                                        <input type="text" name="precioUnidad" class="form-control inp-precio" value="0" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control inp-subtotal"
                                               value="@d.subtotal" readonly />
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-danger btn-xs btn-eliminar-fila">
                                            <span class="glyphicon glyphicon-trash"></span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {

                            <tr>
                                <td>
                                    <select name="idProducto" class="form-control sel-producto">
                                        <option value="">-- Seleccione --</option>
                                        @foreach (var p in Model.Productos)
                                        {
                                            <option value="@p.Value">@p.Text</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input type="number" name="cantidad" class="form-control inp-cantidad" value="1" min="1" />
                                </td>
                                <td>
                                    <input type="text" name="precioUnidad" class="form-control inp-precio" value="0" />
                                </td>
                                <td>
                                    <input type="text" class="form-control inp-subtotal" value="0.00" readonly />
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-danger btn-xs btn-eliminar-fila">
                                        <span class="glyphicon glyphicon-trash"></span>
                                    </button>
                                </td>
                            </tr>

                        }
                    </tbody>
                    <tfoot>
                        <tr class="active">
                            <td colspan="3" class="text-right"><strong>TOTAL:</strong></td>
                            <td>
                                <input type="text" id="txtTotalGeneral" class="form-control"
                                       value="0.00" readonly style="font-weight:bold;" />
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>

                <p class="text-muted small">
                    <span class="glyphicon glyphicon-info-sign"></span>
                    El total se calcula automáticamente. Haga clic en "+ Agregar producto" para añadir líneas.
                </p>
            </div>
        </div>

        <!-- ===== BOTONES ===== -->
        <div class="form-group">
            <div id="debugInfo" class="alert alert-info"></div>


            <button type="submit" class="btn btn-primary btn-lg">
                <span class="glyphicon glyphicon-floppy-disk"></span> Guardar Factura
            </button>
            @Html.ActionLink("Cancelar", "mantFacturas", null, new { @class = "btn btn-default btn-lg" })
        </div>
    }
</div>


<!-- Template para nueva fila (oculto) -->
<table style="display:none">
    <tbody id="filaTemplate">
        <tr>
            <td>
                <select class="form-control sel-producto">
                    <option value="">-- Seleccione --</option>
                    @foreach (var p in Model.Productos)
                    {
                        <option value="@p.Value">@p.Text</option>
                    }
                </select>
            </td>
            <td>
                <input type="number" class="form-control inp-cantidad" value="1" min="1" />
            </td>
            <td>
                <input type="text" class="form-control inp-precio" value="0" />
            </td>
            <td>
                <input type="text" class="form-control inp-subtotal" value="0.00" readonly />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-danger btn-xs btn-eliminar-fila">
                    <span class="glyphicon glyphicon-trash"></span>
                </button>
            </td>
        </tr>
    </tbody>
</table>

@section Scripts {
    <script>
        $(function () {

            // ---- Extraer precio del texto de la opción ----
            function getPrecioDeSelect(sel) {
                var texto = $(sel).find('option:selected').text(); 
                var match = texto.match(/\[([0-9.]+)\]/);
                return match ? parseFloat(match[1]) : 0;
            }

            // ---- Recalcular subtotal de una fila ----
            function recalcularFila(fila) {
                var cant = parseFloat($(fila).find('.inp-cantidad').val()) || 0;
                var precio = parseFloat($(fila).find('.inp-precio').val()) || 0;
                var sub = (cant * precio).toFixed(2);
                $(fila).find('.inp-subtotal').val(sub);
                recalcularTotal();
            }

            // ---- Recalcular total general ----
            function recalcularTotal() {
                var total = 0;
                $('#tbodyDetalles .inp-subtotal').each(function () {
                    total += parseFloat($(this).val()) || 0;
                });
                $('#txtTotalGeneral').val(total.toFixed(2));
            }

            // ---- Bind eventos en una fila ----
            function bindFila(fila) {
                // Al cambiar producto → autocompletar precio
                $(fila).find('.sel-producto').on('change', function () {
                    var precio = getPrecioDeSelect(this);
                    $(this).closest('tr').find('.inp-precio').val(precio.toFixed(2));
                    recalcularFila($(this).closest('tr'));
                });

                $(fila).find('.inp-cantidad, .inp-precio').on('input', function () {
                    recalcularFila($(this).closest('tr'));
                });

                $(fila).find('.btn-eliminar-fila').on('click', function () {
                    $(this).closest('tr').remove();
                    recalcularTotal();
                });
            }

           

            // ---- Agregar nueva fila ----
            $('#btnAgregarFila').on('click', function () {
                var nuevaFila = $('#filaTemplate tr').first().clone(false);
                nuevaFila.find('.sel-producto').attr('name', 'idProducto');
                nuevaFila.find('.inp-cantidad').attr('name', 'cantidad');
                nuevaFila.find('.inp-precio').attr('name', 'precioUnidad');
                $('#tbodyDetalles').append(nuevaFila);
                bindFila(nuevaFila);
                recalcularTotal();
            });

            // ---- Bind filas existentes al cargar ----
            $('#tbodyDetalles tr').each(function () {
                bindFila(this);
            });

            recalcularTotal();

            // ---- Validar antes de enviar ----
            $('#formFactura').on('submit', function (e) {
                if ($('#tbodyDetalles tr').length === 0) {
                    alert('Debe agregar al menos un producto a la factura.');
                    e.preventDefault();
                    return false;
                }
                var sinProducto = false;
                $('#tbodyDetalles .sel-producto').each(function () {
                    if (!$(this).val()) sinProducto = true;
                });
                if (sinProducto) {
                    alert('Hay filas sin producto seleccionado. Por favor complete o elimínelas.');
                    e.preventDefault();
                    return false;
                }
            });
        });

    </script>
}
