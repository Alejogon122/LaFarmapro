@model LaFarmapro.Models.viewModels.CAgregarFactura

@{
    ViewBag.Title = "Agregar Factura";
}

<div class="container mt-4">
    <h2>Nueva Factura</h2>
    <hr />

    @using (Html.BeginForm("agregarFactura", "Facturas", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(m => m.fecha, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.fecha, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.fecha, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.metodoPago, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.DropDownListFor(m => m.metodoPago,
                        new SelectList(new[] {
                            new { Value = "EFFECTIVO", Text = "Efectivo" },
                            new { Value = "TARJETA", Text = "Tarjeta" },
                           
                        }, "Value", "Text"),
                        "-- Seleccione --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.metodoPago, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.total, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.total, new { @class = "form-control", type = "number", step = "0.01", min = "0", placeholder = "0.00" })
                    @Html.ValidationMessageFor(m => m.total, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.idCliente, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.DropDownListFor(m => m.idCliente, Model.Clientes, "-- Seleccione cliente --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.idCliente, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-3 col-md-6">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    @Html.ActionLink("Cancelar", "mantFacturas", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    }
</div>

