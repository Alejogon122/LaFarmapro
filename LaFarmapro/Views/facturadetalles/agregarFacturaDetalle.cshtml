
@model LaFarmapro.Models.viewModels.CAgregarFacturaDetalle

@{
    ViewBag.Title = "Agregar Detalle de Factura";
}

<div class="container mt-4">
    <h2>Agregar Detalle de Factura</h2>
    <hr />

    @using (Html.BeginForm("agregarFacturaDetalle", "FacturaDetalles", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(m => m.idFactura, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.DropDownListFor(m => m.idFactura, Model.Facturas, "-- Seleccione factura --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.idFactura, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.idProducto, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.DropDownListFor(m => m.idProducto, Model.Productos, "-- Seleccione producto --", new { @class = "form-control", id = "selectProducto" })
                    @Html.ValidationMessageFor(m => m.idProducto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.cantidad, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.cantidad, new { @class = "form-control", type = "number", min = "1", id = "txtCantidad" })
                    @Html.ValidationMessageFor(m => m.cantidad, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.precioUnidad, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.precioUnidad, new { @class = "form-control", type = "number", step = "0.01", min = "0", id = "txtPrecio" })
                    @Html.ValidationMessageFor(m => m.precioUnidad, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.subtotal, new { @class = "control-label col-md-3" })
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.subtotal, new { @class = "form-control", id = "txtSubtotal", @readonly = "readonly" })
                    @Html.ValidationMessageFor(m => m.subtotal, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-3 col-md-6">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    @Html.ActionLink("Cancelar", "mantFacturaDetalles", null, new { @class = "btn btn-default" })
                </div>
            </div>
        </div>
    }
</div>

@section scripts {
    <script>
        function calcularSubtotal() {
            var cantidad = parseFloat(document.getElementById('txtCantidad').value) || 0;
            var precio = parseFloat(document.getElementById('txtPrecio').value) || 0;
            document.getElementById('txtSubtotal').value = (cantidad * precio).toFixed(2);
        }
        document.getElementById('txtCantidad').addEventListener('input', calcularSubtotal);
        document.getElementById('txtPrecio').addEventListener('input', calcularSubtotal);
    </script>
}
