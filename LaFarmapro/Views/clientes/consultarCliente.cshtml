@model LaFarmapro.Models.viewModels.CListaClientes

@{
    ViewBag.Title = "Detalle del Cliente";
}

<div class="container mt-4">
    <h2>Detalle del Cliente</h2>
    <hr />

    <div class="panel panel-default">
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>Identificación</dt>
                <dd>@Model.identificacionCliente</dd>

                <dt>Nombre</dt>
                <dd>@Model.nombreCliente</dd>

                <dt>Apellido</dt>
                <dd>@Model.apellidoCliente</dd>

                <dt>Correo</dt>
                <dd>@Model.correoCliente</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        @Html.ActionLink("Editar", "actualizarCliente", new { id = Model.idCliente }, new { @class = "btn btn-warning" })
        @Html.ActionLink("Volver a la lista", "mantClientes", null, new { @class = "btn btn-default" })
    </div>
</div>

