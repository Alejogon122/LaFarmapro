@model IEnumerable<LaFarmapro.Models.viewModels.CListaClientes>
@using System.Linq

@{
    ViewBag.Title = "Mantenimiento de Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Clientes</h2>
        @Html.ActionLink("+ Agregar Cliente", "agregarCliente", "Clientes", null, new { @class = "btn btn-success" })
    </div>

    <table class="table table-striped table-bordered table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Identificación</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Correo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.identificacionCliente</td>
                    <td>@item.nombreCliente</td>
                    <td>@item.apellidoCliente</td>
                    <td>@item.correoCliente</td>
                    <td>
                        @Html.ActionLink("Ver", "consultarCliente", new { id = item.idCliente }, new { @class = "btn btn-info btn-xs" })
                        @Html.ActionLink("Editar", "actualizarCliente", new { id = item.idCliente }, new { @class = "btn btn-warning btn-xs" })
                        @Html.ActionLink("Eliminar", "eliminarCliente", new { id = item.idCliente }, new { @class = "btn btn-danger btn-xs", onclick = "return confirm('¿Está seguro que desea eliminar este cliente?');" })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No hay clientes registrados.</div>
    }
</div>

