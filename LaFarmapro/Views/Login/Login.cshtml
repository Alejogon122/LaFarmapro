
@model LaFarmapro.Models.viewmodels.CLogin

@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #e0f7fa, #fff9c4);
        min-height: 100vh;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        padding: 40px;
        margin-top: 80px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .login-header h2 {
            font-size: 2em;
            font-weight: bold;
            color: #2c3e50;
            font-family: Arial, sans-serif;
        }

        .login-header p {
            color: #7f8c8d;
            font-size: 1em;
        }

        .login-header .glyphicon {
            font-size: 3em;
            color: #3498db;
            margin-bottom: 10px;
        }

    .btn-login {
        background-color: #3498db;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px;
        font-size: 1em;
        width: 100%;
        margin-top: 10px;
        transition: background-color 0.3s;
    }

        .btn-login:hover {
            background-color: #2980b9;
            color: white;
        }

    .form-control {
        border-radius: 8px;
        border: 1px solid #dce1e7;
        padding: 10px;
    }

        .form-control:focus {
            border-color: #3498db;
            box-shadow: 0 0 6px rgba(52, 152, 219, 0.4);
        }

    label {
        font-weight: bold;
        color: #2c3e50;
    }
</style>

<br />

<!-- MODAL MENSAJES -->
@if (ViewBag.ValorMensaje != null)
{
    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Mensaje</h4>
                </div>

                <div class="modal-body">
                    @if (ViewBag.ValorMensaje == 1)
                    {
                        <div class="alert alert-success">
                            <span class="glyphicon glyphicon-ok"></span>
                            @ViewBag.MensajeProceso
                        </div>
                    }
                    else if (ViewBag.ValorMensaje == 0)
                    {
                        <div class="alert alert-danger">
                            <span class="glyphicon glyphicon-remove"></span>
                            @ViewBag.MensajeProceso
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">
                        Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<!-- LOGIN -->
<div class="container">
    <div class="row">
        <div class="col-md-4 col-md-offset-4">

            <div class="login-card">

                <div class="login-header">
                    <span class="glyphicon glyphicon-user"></span>
                    <h2>La Farmacia</h2>
                    <p>Ingrese sus credenciales para continuar</p>
                </div>

                @using (Html.BeginForm("Ingresar", "Login", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <!-- USUARIO -->
                    <div class="form-group">
                        @Html.LabelFor(u => u.user)
                        <div class="input-group">
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-envelope"></span>
                            </span>
                            @Html.TextBoxFor(u => u.user, new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese su usuario"
                            })
                        </div>
                        @Html.ValidationMessageFor(u => u.user, "", new
                        {
                            style = "color:red; font-weight:bold;"
                        })
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group">
                        @Html.LabelFor(u => u.password)
                        <div class="input-group">
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-lock"></span>
                            </span>
                            @Html.PasswordFor(u => u.password, new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese su contraseña"
                            })
                        </div>
                        @Html.ValidationMessageFor(u => u.password, "", new
                        {
                            style = "color:red; font-weight:bold;"
                        })
                    </div>

                    <!-- BOTÓN -->
                    <button type="submit" class="btn-login">
                        <span class="glyphicon glyphicon-log-in"></span>
                        Iniciar Sesión
                    </button>
                }

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#myModal').modal('show');
        });
    </script>
}
